# Public — production: use your canonical https URL (e.g. https://www.yourdomain.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional SEO (Search Console / Bing Webmaster meta tag content)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# NEXT_PUBLIC_BING_SITE_VERIFICATION=
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server only
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Paystack (GHS) — production: use sk_live_ / pk_live_ from Paystack dashboard
PAYSTACK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_...

# Mobile Money — set false in production when real providers are wired
MOBILE_MONEY_MOCK=true

# One-time admin bootstrap (remove ADMIN_BOOTSTRAP_PASSWORD after `npm run bootstrap:admin`)

